{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and profile data stored in Firestore",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "preferredLanguage": {
          "type": "string",
          "enum": ["en", "te"],
          "description": "The user's preferred interface language"
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark"],
          "description": "The user's preferred UI theme"
        }
      },
      "required": ["displayName", "email"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user-specific settings and preferences"
    }
  }
}