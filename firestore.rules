rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HOMILLU SECURITY RULES - PROTOTYPING MODE
     * 
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership and shared-household model. Security is 
     * prioritized through path-based authorization for individual users and member-map 
     * validation for shared household data. 
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Checks if the user is a member of a household based on the 'members' map in a document
    function isMemberInMap(membersMap) {
      return isSignedIn() && (membersMap[request.auth.uid] != null || membersMap.admin == request.auth.uid);
    }

    // Checks membership of a household by reading the parent household document
    function checkHouseholdMembership(householdId) {
      return (isSignedIn() && request.auth.uid == householdId) || 
             (exists(/databases/$(database)/documents/households/$(householdId)) && 
              isMemberInMap(get(/databases/$(database)/documents/households/$(householdId)).data.members));
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    // --- HOUSEHOLDS ---
    match /households/{householdId} {
      allow get: if (isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.members);
      allow list: if false; 
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if resource != null && ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.members)) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if (resource != null && resource.data.ownerId == request.auth.uid) || (isSignedIn() && request.auth.uid == householdId);
    }

    // --- HOUSEHOLD SUBCOLLECTIONS ---
    match /households/{householdId}/{collection}/{docId} {
      function isHouseholdSubcollection() {
        return collection in ['tasks', 'shoppingListItems', 'calendarEvents', 'persons', 'relationships', 'moments'];
      }
      allow get: if isHouseholdSubcollection() && ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.householdMembers));
      allow list: if isHouseholdSubcollection() && checkHouseholdMembership(householdId);
      allow create: if isHouseholdSubcollection() && checkHouseholdMembership(householdId) && request.resource.data.householdId == householdId;
      allow update: if isHouseholdSubcollection() && resource != null && ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.householdMembers)) && request.resource.data.householdId == resource.data.householdId;
      allow delete: if isHouseholdSubcollection() && resource != null && ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.householdMembers));
    }

    // --- COLLECTION GROUP RULES (For Invitations) ---
    match /{path=**}/persons/{personId} {
      // Allow users to find their own person record across households via email
      allow list: if isSignedIn() && request.auth.token.email != null && resource.data.email == request.auth.token.email;
      // Allow the user to confirm their own participation
      allow update: if isSignedIn() && resource.data.email == request.auth.token.email && request.resource.data.isConfirmed == true;
    }

    // --- DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}