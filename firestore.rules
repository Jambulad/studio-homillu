rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HOMILLU SECURITY RULES - PROTOTYPING MODE
     * 
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership and shared-household model. 
     * Security is prioritized through path-based authorization for individual users 
     * and member-map validation for shared household data.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Checks if the user is a member of a household based on the 'members' map
    function isMemberInMap(membersMap) {
      return isSignedIn() && (membersMap[request.auth.uid] != null || membersMap.admin == request.auth.uid);
    }

    // Checks membership of a household by reading the parent household document
    function checkHouseholdMembership(householdId) {
      return (isSignedIn() && request.auth.uid == householdId) || 
             (exists(/databases/$(database)/documents/households/$(householdId)) && 
              isMemberInMap(get(/databases/$(database)/documents/households/$(householdId)).data.members));
    }

    // --- COLLECTION GROUP RULES (For Invitations) ---
    // These rules are required for queries that search across all households.
    match /{path=**}/persons/{personId} {
      // Allow listing ONLY if the query filter strictly matches the user's authenticated email.
      // This satisfies the "safety proof" required by the Firestore rules engine for collection groups.
      allow list: if isSignedIn() && 
                    request.auth.token.email != null && 
                    request.query.filters.email == request.auth.token.email;
      
      // Allow reading individual documents if the email matches.
      allow get: if isSignedIn() && 
                    resource.data.email == request.auth.token.email;
      
      // Allow a user to confirm their own participation status.
      allow update: if isSignedIn() && 
                      resource.data.email == request.auth.token.email && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isConfirmed']);
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    // --- HOUSEHOLDS ---
    match /households/{householdId} {
      allow get: if (isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.members);
      allow list: if false; 
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if resource != null && 
                      ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.members)) && 
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if (resource != null && resource.data.ownerId == request.auth.uid) || 
                      (isSignedIn() && request.auth.uid == householdId);
    }

    // --- HOUSEHOLD SUBCOLLECTIONS ---
    match /households/{householdId}/{collection}/{docId} {
      function isHouseholdSubcollection() {
        return collection in ['tasks', 'shoppingListItems', 'calendarEvents', 'persons', 'relationships', 'moments'];
      }
      
      allow get: if isHouseholdSubcollection() && 
                    ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.householdMembers));
      
      allow list: if isHouseholdSubcollection() && checkHouseholdMembership(householdId);
      
      allow create: if isHouseholdSubcollection() && 
                      checkHouseholdMembership(householdId) && 
                      request.resource.data.householdId == householdId;
      
      allow update: if isHouseholdSubcollection() && 
                      resource != null && 
                      ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.householdMembers)) && 
                      request.resource.data.householdId == resource.data.householdId;
      
      allow delete: if isHouseholdSubcollection() && 
                      resource != null && 
                      ((isSignedIn() && request.auth.uid == householdId) || isMemberInMap(resource.data.householdMembers));
    }

    // --- DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}